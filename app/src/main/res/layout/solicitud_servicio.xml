<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Solicitar Servicio"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/azulVerde"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Selecciona Ubicación"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <Spinner
            android:id="@+id/spinnerDirecciones"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/btn_dropdown"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnToggleDireccion"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agregar nueva dirección"
            android:layout_gravity="end"
            android:textColor="@color/azulVerde"/>

        <LinearLayout
            android:id="@+id/containerNuevaDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#FFFFFF"
            android:padding="15dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nueva Dirección"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <EditText android:id="@+id/etCalle" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Calle"/>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/etNumero" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Número"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zona:"
                android:layout_marginTop="8dp"
                android:textStyle="bold"/>

            <Spinner
                android:id="@+id/spinnerZonas"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:drawable/btn_dropdown"
                android:layout_marginTop="4dp"/>

            <EditText android:id="@+id/etColonia" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Colonia"/>
            <EditText android:id="@+id/etMunicipio" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Municipio"/>
            <EditText android:id="@+id/etEstado" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Estado"/>
            <!-- Campo País eliminado del diseño -->
            <EditText android:id="@+id/etReferencias" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Referencias"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Detalles del Servicio"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <EditText
            android:id="@+id/etFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha (YYYY-MM-DD)"
            android:focusable="false"
            android:layout_marginTop="10dp"/>

        <EditText
            android:id="@+id/etHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hora (HH:MM:SS)"
            android:focusable="false"
            android:layout_marginTop="10dp"/>

        <EditText
            android:id="@+id/etDescServicio"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Describe qué necesitas..."
            android:gravity="top"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnConfirmarSolicitud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmar Solicitud"
            android:backgroundTint="@color/azulVerde"
            android:layout_marginTop="30dp"
            android:padding="15dp"/>

    </LinearLayout>
</ScrollView>
