<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stitchOutlineVariant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Bloque de fecha -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@color/stitchSurfaceContainerLow">

            <TextView
                android:id="@+id/tvFechaServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:textColor="@color/stitchOnSurfaceVariant"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/stitchPrimary" />
        </LinearLayout>

        <!-- Detalles del servicio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <!-- Fila: nombre + estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvNombreTrabajador"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nombre del Trabajador"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/stitchOnSurface"
                    android:fontFamily="sans-serif-medium" />

                <!-- Badge estado -->
                <TextView
                    android:id="@+id/tvEstadoServicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pendiente"
                    android:textSize="11sp"
                    android:textColor="@color/stitchPrimary"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@color/stitchSurfaceContainer"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Separador visual -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stitchOutlineVariant"
                android:layout_marginVertical="8dp" />

            <!-- Flecha acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver detalles →"
                    android:textSize="12sp"
                    android:textColor="@color/stitchPrimary"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
