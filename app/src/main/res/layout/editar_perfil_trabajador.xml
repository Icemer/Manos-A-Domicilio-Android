<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stitchBackground">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/stitchSurfaceContainerLowest"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvEditarPerfilTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editar Perfil Profesional"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/stitchOnSurface"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Scrollable form -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/menuInferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Description card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stitchOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción Profesional"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/stitchOnSurface"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/etEditarDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:hint="Cuéntanos sobre tu experiencia..."
                        android:inputType="textMultiLine"
                        android:gravity="top|start"
                        android:textColor="@color/stitchOnSurface"
                        android:textColorHint="@color/stitchOnSurfaceVariant"
                        android:textSize="14sp"
                        android:padding="12dp"
                        android:background="@color/stitchSurfaceContainerLow" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Availability card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stitchOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disponibilidad"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/stitchOnSurface"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activa si estás disponible para trabajar"
                            android:textSize="12sp"
                            android:textColor="@color/stitchOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/swDisponibilidad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Manage zones row -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stitchOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/stitchSurfaceContainerLowest"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvGestionarZonas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gestionar Zonas de Trabajo"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/stitchPrimary"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/stitchOutline" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarPerfil"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Guardar Cambios"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/stitchPrimary"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom menu -->
    <include
        layout="@layout/bottom_menu"
        android:id="@+id/menuInferior"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
