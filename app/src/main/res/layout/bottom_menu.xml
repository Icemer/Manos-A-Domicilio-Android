<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="vertical"
    android:background="@color/stitchSurfaceContainerLowest"
    android:elevation="16dp">

    <!-- Top divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/stitchCardBorder" />

    <!-- Tabs row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Tab: Inicio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivHome"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_home"
                app:tint="@color/stitchPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/stitchPrimary"
                android:layout_marginTop="3dp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Tab: Historial -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivHistorial"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_historial"
                app:tint="@color/stitchNavInactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reservas"
                android:textSize="10sp"
                android:textColor="@color/stitchNavInactive"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Tab: Favoritos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivFavoritos"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_favorites_menu"
                app:tint="@color/stitchNavInactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favoritos"
                android:textSize="10sp"
                android:textColor="@color/stitchNavInactive"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Tab: Perfil -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivPerfil"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_perfil"
                app:tint="@color/stitchNavInactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="10sp"
                android:textColor="@color/stitchNavInactive"
                android:layout_marginTop="3dp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
