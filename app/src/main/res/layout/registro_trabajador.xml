<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stitchBackground">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/stitchSurfaceContainerLowest"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/logo_chiquito"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Registro de Profesional"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/stitchOnSurface"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Scrollable form -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/menuInferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Category section -->
            <TextView
                android:id="@+id/tvLabelCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría de servicio"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/stitchOnSurfaceVariant"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stitchOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                <Spinner
                    android:id="@+id/spinnerCategorias"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/stitchOnSurface" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Availability section -->
            <TextView
                android:id="@+id/tvLabelDisponibilidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disponibilidad"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/stitchOnSurfaceVariant"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stitchOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                <Spinner
                    android:id="@+id/spinnerDisponibilidad"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/stitchOnSurface" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción profesional"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/stitchOnSurfaceVariant"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cuéntanos sobre tu experiencia..."
                app:boxStrokeColor="@color/stitchOutlineVariant"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:textColor="@color/stitchOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistrarse"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Completar Registro"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/stitchPrimary"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom menu -->
    <include
        layout="@layout/bottom_menu"
        android:id="@+id/menuInferior"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
