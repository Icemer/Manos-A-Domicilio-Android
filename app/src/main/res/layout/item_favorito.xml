<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stitchOutlineVariant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Circular avatar -->
        <androidx.cardview.widget.CardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/ivAvatarFavorito"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/avatar_perfil"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <!-- Name + category -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvNombreFavorito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Trabajador"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/stitchOnSurface"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvCategoriaFavorito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textSize="13sp"
                android:textColor="@color/stitchOnSurfaceVariant"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Chevron -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="24sp"
            android:textColor="@color/stitchOutline" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
