<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stitchBackground"
    tools:context=".view.HistorialServicios">

    <!-- ===== TOP APP BAR ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/stitchSurfaceContainerLowest"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mis Reservas"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/stitchOnSurface"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- ===== SECTION LABEL ===== -->
    <TextView
        android:id="@+id/tvHistorialServicios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial de Servicios"
        android:textSize="14sp"
        android:textColor="@color/stitchOnSurfaceVariant"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== RECYCLER VIEW ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistorialServicios"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvHistorialServicios"
        app:layout_constraintBottom_toTopOf="@id/menuInferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== BOTTOM MENU ===== -->
    <include
        android:id="@+id/menuInferior"
        layout="@layout/bottom_menu"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
