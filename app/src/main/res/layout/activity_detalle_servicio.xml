<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stitchBackground">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/stitchSurfaceContainerLowest"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Detalle del Servicio"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/stitchOnSurface"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/menuInferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Service info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stitchOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profesional"
                        android:textSize="12sp"
                        android:textColor="@color/stitchOnSurfaceVariant"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvDetalleNombreTrabajador"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Trabajador"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/stitchOnSurface"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="14dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/stitchOutlineVariant"
                        android:layout_marginBottom="14dp" />

                    <!-- Date row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Fecha"
                            android:textSize="13sp"
                            android:textColor="@color/stitchOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvDetalleFecha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/stitchOnSurface" />
                    </LinearLayout>

                    <!-- Status row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Estado"
                            android:textSize="13sp"
                            android:textColor="@color/stitchOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvDetalleEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendiente"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/stitchPendingText"
                            android:background="@color/stitchPendingBg"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <!-- Amount row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Monto a pagar"
                            android:textSize="13sp"
                            android:textColor="@color/stitchOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvMontoAPagar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/stitchPrimary" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Description card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stitchOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/stitchOnSurface"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetalleDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:textColor="@color/stitchOnSurfaceVariant"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelarServicio"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Cancelar"
                    android:textSize="14sp"
                    android:textColor="@color/stitchPrimary"
                    app:strokeColor="@color/stitchOutlineVariant"
                    app:cornerRadius="10dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPagar"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Pagar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/stitchPrimary"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <!-- Rating form (shown/hidden by Java) -->
            <LinearLayout
                android:id="@+id/llFormularioCalificacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/stitchOutlineVariant"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calificar Servicio"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/stitchOnSurface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="12dp" />

                        <RatingBar
                            android:id="@+id/rbCalificacion"
                            style="?android:attr/ratingBarStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:numStars="5"
                            android:stepSize="1"
                            android:progressTint="@color/stitchStar"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Comentarios opcionales"
                            app:boxStrokeColor="@color/stitchOutlineVariant"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etComentarios"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:inputType="textMultiLine"
                                android:gravity="top"
                                android:textColor="@color/stitchOnSurface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEnviarCalificacion"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Enviar Calificación"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/stitchPrimary"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Rating summary (shown/hidden by Java) -->
            <LinearLayout
                android:id="@+id/llResumenCalificaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/stitchOutlineVariant"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/stitchSurfaceContainerLowest">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resumen de Calificaciones"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/stitchOnSurface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tu calificación al profesional"
                                android:textSize="13sp"
                                android:textColor="@color/stitchOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvCalificacionDada"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/stitchStar" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Calificación recibida"
                                android:textSize="13sp"
                                android:textColor="@color/stitchOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvCalificacionRecibida"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/stitchStar" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom menu -->
    <include
        layout="@layout/bottom_menu"
        android:id="@+id/menuInferior"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
